#!/usr/bin/env python3
"""ccb - Claude Code Bookmark

A CLI tool to bookmark your favorite prompts from Claude Code session
history. Run it in a separate shell session so it never touches your
running Claude Code context.

- Data source: ~/.claude/projects/<encoded-cwd>/*.jsonl (read-only)
- Bookmarks:   ~/.claude/ccb/<encoded-cwd>.jsonl
- Dependencies: Python standard library only (curses)
"""

import argparse
import curses
import json
import os
import re
import sys
import unicodedata
from datetime import datetime, timezone
from pathlib import Path

VERSION = "0.2.0"
CLAUDE_PROJECTS_DIR = Path.home() / ".claude" / "projects"
CCB_DIR = Path.home() / ".claude" / "ccb"
PICK_LIMIT = 20

# Messages starting with these prefixes are metadata, not user prompts
META_PREFIXES = (
    "<command-name>",
    "<command-message>",
    "<local-command-stdout>",
    "<local-command-caveat>",
    "<system-reminder>",
    "<task-notification>",
    "Caveat: The messages below",
    "[Request interrupted",
)


# ---------------------------------------------------------------------------
# Path encoding
# ---------------------------------------------------------------------------

def encode_cwd(path: str) -> str:
    """Encode a cwd the same way Claude Code names its projects directories."""
    return re.sub(r"[^A-Za-z0-9]", "-", path)


def project_dir_for(cwd: str) -> Path:
    return CLAUDE_PROJECTS_DIR / encode_cwd(cwd)


def bookmark_file_for(cwd: str) -> Path:
    return CCB_DIR / (encode_cwd(cwd) + ".jsonl")


# ---------------------------------------------------------------------------
# Prompt extraction from session history
# ---------------------------------------------------------------------------

def _text_from_content(content):
    """Extract prompt text from a user record's message.content.

    Records containing tool_result items are tool output, not user input,
    so they are excluded.
    """
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts = []
        for item in content:
            if not isinstance(item, dict):
                continue
            if item.get("type") == "tool_result":
                return None
            if item.get("type") == "text":
                text = item.get("text") or ""
                if not text.lstrip().startswith(META_PREFIXES):
                    parts.append(text)
        return "\n".join(parts)
    return None


def extract_prompts(project_dir: Path):
    """Collect user prompts as (timestamp, text) from session JSONL files.

    Returns deduplicated entries, newest first.
    """
    entries = []
    for jsonl_path in sorted(project_dir.glob("*.jsonl")):
        try:
            with jsonl_path.open(encoding="utf-8", errors="replace") as f:
                for line in f:
                    line = line.strip()
                    if not line:
                        continue
                    try:
                        rec = json.loads(line)
                    except json.JSONDecodeError:
                        continue
                    if rec.get("type") != "user":
                        continue
                    if rec.get("isSidechain") or rec.get("isMeta"):
                        continue
                    message = rec.get("message") or {}
                    text = _text_from_content(message.get("content"))
                    if not text:
                        continue
                    text = text.strip()
                    if not text or text.startswith(META_PREFIXES):
                        continue
                    entries.append((rec.get("timestamp") or "", text))
        except OSError:
            continue

    # ISO 8601 strings sort chronologically as plain strings
    entries.sort(key=lambda e: e[0], reverse=True)

    seen = set()
    result = []
    for ts, text in entries:
        if text in seen:
            continue
        seen.add(text)
        result.append((ts, text))
    return result


# ---------------------------------------------------------------------------
# Bookmark storage
# ---------------------------------------------------------------------------

def load_bookmarks(path: Path):
    """Read the bookmark file and return records in file order (oldest first)."""
    records = []
    if not path.exists():
        return records
    with path.open(encoding="utf-8", errors="replace") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                rec = json.loads(line)
            except json.JSONDecodeError:
                continue
            if isinstance(rec, dict) and rec.get("text"):
                records.append(rec)
    return records


def save_bookmarks(cwd: str, texts):
    """Append new texts only (skip already-bookmarked ones). Returns count saved."""
    path = bookmark_file_for(cwd)
    existing = {rec["text"] for rec in load_bookmarks(path)}
    new_texts = [t for t in texts if t not in existing]
    if not new_texts:
        return 0
    CCB_DIR.mkdir(parents=True, exist_ok=True)
    now = datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")
    with path.open("a", encoding="utf-8") as f:
        for text in new_texts:
            rec = {"text": text, "bookmarked_at": now, "cwd": cwd}
            f.write(json.dumps(rec, ensure_ascii=False) + "\n")
    return len(new_texts)


def delete_bookmarks(cwd: str, texts_to_delete):
    """Remove records matching the given texts. Returns count deleted."""
    path = bookmark_file_for(cwd)
    records = load_bookmarks(path)
    remaining = [r for r in records if r["text"] not in texts_to_delete]
    deleted = len(records) - len(remaining)
    if deleted:
        with path.open("w", encoding="utf-8") as f:
            for rec in remaining:
                f.write(json.dumps(rec, ensure_ascii=False) + "\n")
    return deleted


# ---------------------------------------------------------------------------
# Display helpers (East Asian width aware)
# ---------------------------------------------------------------------------

def display_width(s: str) -> int:
    return sum(2 if unicodedata.east_asian_width(c) in "WF" else 1 for c in s)


def truncate_to_width(s: str, width: int) -> str:
    """Truncate to the given display width, appending … when cut."""
    if display_width(s) <= width:
        return s
    result = []
    used = 0
    for c in s:
        w = 2 if unicodedata.east_asian_width(c) in "WF" else 1
        if used + w > width - 1:
            break
        result.append(c)
        used += w
    return "".join(result) + "…"


def wrap_to_width(s: str, width: int):
    """Wrap text to the given display width and return the lines."""
    lines = []
    for raw_line in s.split("\n"):
        if not raw_line:
            lines.append("")
            continue
        current = []
        used = 0
        for c in raw_line:
            w = 2 if unicodedata.east_asian_width(c) in "WF" else 1
            if used + w > width:
                lines.append("".join(current))
                current = [c]
                used = w
            else:
                current.append(c)
                used += w
        lines.append("".join(current))
    return lines


def one_line(s: str) -> str:
    return re.sub(r"\s+", " ", s).strip()


# ---------------------------------------------------------------------------
# TUI
# ---------------------------------------------------------------------------

def init_style():
    """Build the attribute set for the TUI.

    Uses the Claude Code orange as the accent color, degrading gracefully:
    256-color terminals get the closest xterm color, 8-color terminals fall
    back to yellow, and monochrome terminals get bold/dim attributes only.
    """
    style = {
        "accent": curses.A_BOLD,
        "title": curses.A_BOLD,
        "dim": curses.A_DIM,
        "cursor": curses.A_REVERSE,
        "normal": curses.A_NORMAL,
    }
    if not curses.has_colors():
        return style
    try:
        curses.start_color()
        curses.use_default_colors()
        # xterm 173 (#d7875f) is the closest match to Claude Code's #d97757
        accent = 173 if curses.COLORS >= 256 else curses.COLOR_YELLOW
        gray = 245 if curses.COLORS >= 256 else -1
        curses.init_pair(1, accent, -1)
        curses.init_pair(2, gray, -1)
    except curses.error:
        return style
    style["accent"] = curses.color_pair(1) | curses.A_BOLD
    style["title"] = curses.color_pair(1) | curses.A_BOLD
    style["dim"] = curses.color_pair(2)
    style["cursor"] = curses.color_pair(1) | curses.A_BOLD
    return style


def draw_segments(stdscr, y, x, width, segments):
    """Draw (text, attr) segments on one row, clipping at the right edge."""
    for text, attr in segments:
        if x >= width - 1:
            break
        stdscr.addnstr(y, x, truncate_to_width(text, width - 1 - x),
                       width - 1 - x, attr)
        x += display_width(text)


def run_selector(items, title, action_label, confirm=False):
    """Show a checkbox-list TUI.

    items: texts to display
    title: header title
    action_label: what Enter does (e.g. "save", "delete")
    confirm: when true, ask y/n before committing on Enter

    Returns the list of checked texts, or None when cancelled.
    """

    def _main(stdscr):
        curses.curs_set(0)
        stdscr.keypad(True)
        style = init_style()
        # "ccb pick — description" → command part gets the accent color
        cmd_part, _, desc_part = title.partition(" — ")
        cursor = 0
        offset = 0
        checked = [False] * len(items)
        confirming = False

        while True:
            stdscr.erase()
            height, width = stdscr.getmaxyx()

            preview_height = max(3, height // 3)
            list_height = height - preview_height - 4  # header + separator + footer
            if list_height < 1:
                stdscr.addstr(0, 0, "Terminal too small")
                stdscr.refresh()
                key = stdscr.getch()
                if key in (ord("q"), 27):
                    return None
                continue

            if cursor < offset:
                offset = cursor
            elif cursor >= offset + list_height:
                offset = cursor - list_height + 1

            checked_count = sum(checked)
            header_segs = [(" $ ", style["dim"]), (cmd_part, style["title"])]
            if desc_part:
                header_segs.append((f"  # {desc_part}", style["dim"]))
            header_segs.append(
                (f"  ({len(items)} items, {checked_count} checked)",
                 style["dim"]))
            draw_segments(stdscr, 0, 0, width, header_segs)

            for i in range(offset, min(offset + list_height, len(items))):
                y = 1 + (i - offset)
                is_cursor = i == cursor
                pointer = "❯ " if is_cursor else "  "
                mark = "[x]" if checked[i] else "[ ]"
                mark_attr = style["accent"] if checked[i] else style["dim"]
                text_attr = style["cursor"] if is_cursor else style["normal"]
                text = truncate_to_width(one_line(items[i]), width - 10)
                draw_segments(stdscr, y, 0, width, [
                    (pointer, style["cursor"] if is_cursor else style["normal"]),
                    (mark, mark_attr),
                    (" " + text, text_attr),
                ])
                if checked[i] and width > 12:
                    stdscr.addnstr(y, width - 3, "★", 2, style["accent"])

            sep_y = 1 + list_height
            stdscr.hline(sep_y, 0, curses.ACS_HLINE | style["dim"], width)
            if width > 12:
                stdscr.addnstr(sep_y, 1, " PREVIEW ", width - 2, style["dim"])

            preview_lines = wrap_to_width(items[cursor], width - 2)
            visible = preview_lines[: preview_height - 1]
            for j, pline in enumerate(visible):
                stdscr.addnstr(sep_y + 1 + j, 1, pline, width - 2)
            if len(preview_lines) > len(visible):
                more = f"… ({len(preview_lines) - len(visible)} more lines)"
                stdscr.addnstr(sep_y + preview_height, 1,
                               truncate_to_width(more, width - 2),
                               width - 2, style["dim"])

            footer_y = height - 1
            if confirming:
                draw_segments(stdscr, footer_y, 0, width, [
                    (f" {action_label.capitalize()} {checked_count} item(s)? ",
                     curses.A_BOLD),
                    ("(y/n)", style["accent"]),
                ])
            else:
                draw_segments(stdscr, footer_y, 0, width, [
                    (" ↑/↓ j/k", style["accent"]), (" move  ", style["dim"]),
                    ("Space", style["accent"]), (" toggle  ", style["dim"]),
                    ("Enter", style["accent"]),
                    (f" {action_label}  ", style["dim"]),
                    ("q", style["accent"]), (" quit", style["dim"]),
                ])

            stdscr.refresh()
            key = stdscr.getch()

            if confirming:
                if key in (ord("y"), ord("Y")):
                    return [items[i] for i in range(len(items)) if checked[i]]
                if key in (ord("n"), ord("N"), 27, ord("q")):
                    confirming = False
                continue

            if key in (curses.KEY_UP, ord("k")):
                cursor = max(0, cursor - 1)
            elif key in (curses.KEY_DOWN, ord("j")):
                cursor = min(len(items) - 1, cursor + 1)
            elif key == ord(" "):
                checked[cursor] = not checked[cursor]
            elif key in (curses.KEY_ENTER, 10, 13):
                if sum(checked) == 0:
                    continue
                if confirm:
                    confirming = True
                else:
                    return [items[i] for i in range(len(items)) if checked[i]]
            elif key in (ord("q"), 27):
                return None
            elif key == curses.KEY_RESIZE:
                offset = 0

    return curses.wrapper(_main)


# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

def cmd_pick(cwd: str) -> int:
    project_dir = project_dir_for(cwd)
    if not project_dir.is_dir():
        print(f"No Claude Code history found for this directory: {project_dir}")
        return 1

    prompts = extract_prompts(project_dir)
    if not prompts:
        print("No user prompts found in this directory's history.")
        return 1

    items = [text for _, text in prompts[:PICK_LIMIT]]
    selected = run_selector(
        items,
        title="ccb pick — select prompts to bookmark",
        action_label="save",
    )
    if selected is None:
        print("Cancelled.")
        return 0
    saved = save_bookmarks(cwd, selected)
    skipped = len(selected) - saved
    message = f"Saved {saved} bookmark(s)."
    if skipped:
        message += f" ({skipped} already bookmarked, skipped)"
    print(message)
    print(f"Bookmark file: {bookmark_file_for(cwd)}")
    return 0


def cmd_list(cwd: str) -> int:
    path = bookmark_file_for(cwd)
    records = load_bookmarks(path)
    if not records:
        print("No bookmarks for this directory yet. Run `ccb pick` first.")
        return 1

    # Newest first
    items = [rec["text"] for rec in reversed(records)]
    selected = run_selector(
        items,
        title="ccb list — bookmarks (checked items will be removed)",
        action_label="delete",
        confirm=True,
    )
    if selected is None:
        print("Cancelled.")
        return 0
    deleted = delete_bookmarks(cwd, set(selected))
    print(f"Deleted {deleted} bookmark(s).")
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="ccb",
        description="Bookmark your favorite prompts from Claude Code history",
    )
    parser.add_argument("--version", action="version", version=f"ccb {VERSION}")
    subparsers = parser.add_subparsers(dest="command", required=True)
    subparsers.add_parser("pick", help="pick prompts from history and bookmark them")
    subparsers.add_parser("list", help="list bookmarks and remove checked ones")
    args = parser.parse_args()

    if not sys.stdout.isatty() or not sys.stdin.isatty():
        print("ccb requires an interactive terminal.", file=sys.stderr)
        return 1

    cwd = os.getcwd()
    if args.command == "pick":
        return cmd_pick(cwd)
    if args.command == "list":
        return cmd_list(cwd)
    return 1


if __name__ == "__main__":
    sys.exit(main())
